# Environment variables for The Living Constitution
# Copy to .env and fill in real values — NEVER commit .env
#
# Required
DATABASE_URL=postgresql://tlc_user:CHANGE_ME@postgres:5432/tlc_db
REDIS_URL=redis://redis:6379
ANTHROPIC_API_KEY=CHANGE_ME
POSTGRES_DB=tlc_db
POSTGRES_USER=tlc_user
POSTGRES_PASSWORD=CHANGE_ME

# Guardian service
LOG_LEVEL=info
GUARDIAN_CORS_ORIGINS=http://localhost:3000
# Set to 1 to block writes without a valid semgraph ImpactReport
TLC_GUARDIAN_STRICT_SEMGRAPH=0
# Set to 1 to disable auto-generation of ImpactReports
TLC_GUARDIAN_AUTOGEN_DISABLED=0

# Monitoring (only used with --profile monitoring)
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME
