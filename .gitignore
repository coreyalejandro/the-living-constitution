# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules

# next.js
/.next/
/out/

# production
/build

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env*.local
# .envrc is committed (contains variable names, not secrets)

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# macOS
.DS_Store

# Cursor / IDE: track `.cursor/rules/*.mdc` (shared agent rules + search indexing); ignore rest of `.cursor/`
.cursor/*
!.cursor/rules/
!.cursor/rules/**
# OpenMemory: optional machine-local overrides — keep out of git if you use it that way
.cursor/rules/openmemory.mdc

# Claude Code ephemeral worktrees (never gitlink into TLC)
.claude/worktrees/
.claud (old)/

# Governance run artifacts (regenerated locally / in CI; upload via workflow artifact)
verification/runs/*.json
verification/attestations/*.json

# C-RSP structural diff reports from scripts/verify_crsp_template_bundle.sh
verification/c-rsp-structure/

# Python
__pycache__/
*.pyc
*.egg-info/

# Playwright MCP artifacts (screenshots, recordings, etc.)
.playwright-mcp/

# Local failure reports emitted by verifiers (transient)
verification/docs_constitution_failure.json

# Sandbox stress harness (local sentinel + JSONL; regenerate on test runs)
verification/.stress_*.jsonl
verification/.stress_halt_sentinel
CLAUDE.md
AGENTS.md
