{
  "schema_version": "1.0.0",
  "model_id": "tlc-invariant-risk-model",
  "severity_levels": {
    "critical": {
      "description": "System invalid / halt — must block merge and CI",
      "default_escalation": "block"
    },
    "high": {
      "description": "Block verification until resolved",
      "default_escalation": "block"
    },
    "medium": {
      "description": "Warning plus logged; may block per policy",
      "default_escalation": "warn"
    },
    "low": {
      "description": "Informational; does not block by default",
      "default_escalation": "info"
    }
  },
  "escalation_tokens": [
    "block",
    "warn",
    "info",
    "review"
  ]
}
