  ],
  "customization_zones": [
    "profile_specific_invariants",
    "domain_acceptance_criteria",
    "implementation_controls",
    "evidence_paths",
    "execution_plan_payload",
    "domain_product_context",
    "linked_repo_dependency_payload"
  ],
  "required_fields": [
    "Contract Title",
    "Contract ID",
    "Version",
    "Schema Version",
    "Status",
    "Adoption Tier",
    "Topology Mode",
    "Profile Type",
    "Verifier Class",
    "Authoritative Truth Surface"
  ],
  "allowed_values": {
    "status": ["Draft", "Active", "Frozen", "Superseded"],
    "adoption_tier": [
      "Tier-1-MVG",
      "Tier-2-Operational",
      "Tier-3-Constitutional"
    ],
    "topology_mode": ["TLC-Core", "Satellite", "Dual-Topology"],
    "profile_type": [
      "Core",
      "Satellite",
      "Integrated Component",
      "Standalone Application",
      "Dual-Topology"
    ],
    "verifier_class": [
      "core-verifier",
      "satellite-verifier",
      "dual-topology-verifier"
    ],
    "risk_class": ["Low", "Moderate", "High", "Critical"],
    "side_effect_class": [
      "None",
      "Internal",
      "External",
      "Destructive",
      "Regulated"
    ],
    "stop_override_required": ["Yes", "No"],
    "recovery_mode": ["Manual", "Assisted", "Automated", "N/A"]
  },
  "topology_verifier_alignment": {
    "TLC-Core": ["core-verifier"],
    "Satellite": ["satellite-verifier"],
    "Dual-Topology": ["dual-topology-verifier"]
  },
  "lifecycle_transitions": {
    "allowed_edges": [
      ["Draft", "Active"],
      ["Active", "Frozen"],
      ["Frozen", "Superseded"]
    ],
    "evidence_required_on_transition": true
  },
  "tier_minimums": {
    "Tier-1-MVG": [
      "contract_identity",
      "contract_topology_profile",
      "preflight",
      "output_format",
      "instance_declaration"
    ],
    "Tier-2-Operational": [
      "acceptance_criteria",
      "risk_control_classification",
      "rollback_recovery",
      "lifecycle_state_machine",
      "evidence_truth_surface"
    ],
    "Tier-3-Constitutional": [
      "invariants",
      "dependencies_inputs",
      "halt_matrix",
      "conflict_matrix",
      "instance_declaration"
    ]
  },
  "validation_model": {
    "preserve_core_section_order": true,
    "preserve_core_section_titles": true,
    "forbid_core_section_rename": true,
    "forbid_core_section_removal": true,
    "forbid_core_section_insertion_between_ordered_sections": true,
    "allow_customization_only_in_declared_zones": true,
    "reject_unresolved_placeholders_in_executable_instances": true,
    "require_canonical_terminology": true,
    "require_stop_override_when_risk_or_side_effect_triggers": true,
    "require_rollback_recovery_for_tier_2_plus": true,
    "blind_man_execution": {
      "ordered_operations_required_in_executable_instances": true,
      "halt_conditions_required_in_executable_instances": true,
      "success_conditions_required_in_executable_instances": true,
      "major_component_snippets_required_when_material_code_change": true,
      "guided_template_path": "projects/c-rsp/BUILD_CONTRACT.instance.md",
      "canonical_master_template_path": "projects/c-rsp/BUILD_CONTRACT.md",
      "note": "Executable instances must implement Section 6A–6D of the canonical master (Ordered Operations, Halt, Success, Major Component Snippets). The guided template is a workflow artifact and is not an executable instance until copied to an executed path and fully instantiated."
    },
    "authority_order_crsp_a0_1": {
      "description": "Strict precedence for C-RSP template-system files; lower indices do not override higher.",
      "ordered_paths": [
        "projects/c-rsp/BUILD_CONTRACT.md",
        "projects/c-rsp/BUILD_CONTRACT.instance.md",
        "projects/c-rsp/contract-schema.json",
        "projects/c-rsp/CRSP_OUTCOME_TEMPLATE.md",
        "projects/c-rsp/workflows/",
        "projects/*/BUILD_CONTRACT*"
      ],
      "human_readable_map": "projects/c-rsp/CANONICAL_ROLE_MAP.md",
      "invariants": [
        "INVARIANT_SEM_01",
        "INVARIANT_SEM_02",
        "INVARIANT_SEM_03",
        "INVARIANT_SEM_04"
      ]
    }
  }
}
