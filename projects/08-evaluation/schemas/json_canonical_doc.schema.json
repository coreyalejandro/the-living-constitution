{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tlc.local/schemas/json_canonical_doc.schema.json",
  "title": "JSON Canonical Document",
  "type": "object",
  "required": [
    "schema_version",
    "document_id",
    "title",
    "output_markdown",
    "canonical_format",
    "last_generated_utc",
    "body_markdown"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "document_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "output_markdown": {
      "type": "string",
      "pattern": "^[^\\0]+\\.md$"
    },
    "canonical_format": {
      "type": "string",
      "const": "json"
    },
    "last_generated_utc": {
      "type": "string",
      "format": "date-time"
    },
    "body_markdown": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
